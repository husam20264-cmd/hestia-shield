# Hestia Shield v3.0.0 — Production Configuration
# Copy to .env and fill in your values

# === Database ===
HESTIA_DATABASE_URL=postgresql+asyncpg://hestia:change-me@postgres:5432/hestia

# === Redis ===
HESTIA_REDIS_URL=redis://redis:6379/0

# === Authentication ===
HESTIA_JWT_SECRET=generate-a-strong-random-secret-here

# === Data ===
HESTIA_DATA_DIR=/app/data
HESTIA_STORE_RAW_INPUTS=false

# === Rate Limiting ===
HESTIA_RATE_LIMIT_WINDOW=60
HESTIA_RATE_LIMIT_MAX=100

# === Webhooks ===
HESTIA_WEBHOOK_TIMEOUT=10
HESTIA_WEBHOOK_MAX_RETRIES=3

# === CORS ===
HESTIA_ALLOW_ORIGINS=https://your-dashboard.com

# === Server ===
HESTIA_HOST=0.0.0.0
HESTIA_PORT=8000
HESTIA_LOG_LEVEL=INFO
HESTIA_DEBUG=false

# === v1.2.0 — Adaptive Security ===
HESTIA_ML_MODEL_PATH=
HESTIA_POLICY_AUTO_APPLY=false
HESTIA_POLICY_GEN_INTERVAL=100

# === v1.7.0 — Plugin System ===
HESTIA_PLUGIN_DIR=/etc/hestia/plugins

# === v1.8.0 — Alerting & Notifications ===
# Slack
HESTIA_ALERT_SLACK_WEBHOOK_URL=
# Email
HESTIA_ALERT_EMAIL_SMTP_HOST=
HESTIA_ALERT_EMAIL_SMTP_PORT=587
HESTIA_ALERT_EMAIL_USERNAME=
HESTIA_ALERT_EMAIL_PASSWORD=
HESTIA_ALERT_EMAIL_FROM=hestia-shield@localhost
HESTIA_ALERT_EMAIL_TO=
# PagerDuty
HESTIA_ALERT_PAGERDUTY_ROUTING_KEY=

# === v2.0.0 — Self-Healing ===
HESTIA_HEALING_ENABLED=true
HESTIA_HEALING_FP_THRESHOLD=0.05
HESTIA_HEALING_WINDOW=1000
HESTIA_HEALING_MIN_DECISIONS=50
HESTIA_HEALING_COOLDOWN=300
HESTIA_HEALING_FP_TARGET=0.05
HESTIA_HEALING_FN_TARGET=0.02
HESTIA_HEALING_STEP=0.5

# === OpenTelemetry (optional) ===
HESTIA_OTEL_ENABLED=false
HESTIA_OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
HESTIA_OTEL_SERVICE_NAME=hestia-shield

# === PostgreSQL credentials (used by docker-compose) ===
DB_NAME=hestia
DB_USER=hestia
DB_PASSWORD=change-me
