# Hestia Shield Configuration

HESTIA_JWT_SECRET=your-secret-key-here-change-in-production
HESTIA_REDIS_URL=redis://localhost:6379
HESTIA_DATA_DIR=./data
HESTIA_STORE_RAW_INPUTS=false
HESTIA_RATE_LIMIT_WINDOW=60
HESTIA_RATE_LIMIT_MAX=100
HESTIA_WEBHOOK_TIMEOUT=10
HESTIA_WEBHOOK_MAX_RETRIES=3
HESTIA_ALLOW_ORIGINS=https://your-dashboard.com
HESTIA_HOST=0.0.0.0
HESTIA_PORT=8000
HESTIA_DEBUG=false
HESTIA_LOG_LEVEL=INFO